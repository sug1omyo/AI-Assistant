# ============= PERFORMANCE & DATABASE =============
# Redis cache (default: localhost)
REDIS_URL=redis://localhost:6379/0

# MongoDB (Atlas connection string)
# Get your MongoDB URI from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=YOUR_APP

# ============= STABLE DIFFUSION =============
SD_API_URL=http://127.0.0.1:8188
IMAGE_FIRST_MODE=1             # 1 = ưu tiên tạo ảnh khi image tool đang bật
AUTO_START_IMAGE_SERVICES=1    # 1 = khi chạy chatbot sẽ tự bật các service ảnh phụ trợ
AUTO_START_COMFYUI=1
AUTO_START_STABLE_DIFFUSION=1
IMAGE_SERVICE_VISIBLE_WINDOWS=1
COMFYUI_CPU_MODE=auto          # auto = tự thêm --cpu nếu torch không có CUDA
STABLE_DIFFUSION_PORT=7861
STABLE_DIFFUSION_START_COMMAND=  # Optional: custom Windows command if services/stable-diffusion has no webui.bat

# ============= IMAGE GENERATION V2 (Multi-Provider) =============
FAL_API_KEY=                    # fal.ai — https://fal.ai/dashboard/keys
REPLICATE_API_TOKEN=            # Replicate — https://replicate.com/account/api-tokens
BFL_API_KEY=                    # Black Forest Labs — https://api.bfl.ml
TOGETHER_API_KEY=               # Together.ai (FREE tier) — https://api.together.xyz
STEPFUN_API_KEY=                # StepFun — https://platform.stepfun.com
COMFYUI_URL=http://127.0.0.1:8189   # Local ComfyUI (FREE)
IMGBB_API_KEY=                  # ImgBB image hosting — https://api.imgbb.com
IMAGE_GEN_DEFAULT_MODEL=nano-banana-auto   # nano-banana-pro | nano-banana-2 | nano-banana-auto
