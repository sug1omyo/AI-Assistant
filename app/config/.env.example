# Hub Gateway Configuration
HUB_PORT=3000
FLASK_ENV=development
FLASK_SECRET_KEY=ai-assistant-hub-2025-thanhnguyen-secure-key-change-in-production

# Service Ports
CHATBOT_PORT=5000
SPEECH2TEXT_PORT=5001
TEXT2SQL_PORT=5002

# OpenAI API (GPT-4o-mini: $0.15/$0.60 per 1M tokens)
OPENAI_API_KEY=sk-proj-SZNV...YOUR_KEY_HERE...

# DeepSeek API (DeepSeek: $0.14/$0.28 per 1M tokens)
DEEPSEEK_API_KEY=sk-1f010...YOUR_KEY_HERE...

# GROK API (FREE tier from xAI)
GROK_API_KEY=xai-...YOUR_KEY_HERE...

# HuggingFace (for Speech2Text models)
HUGGINGFACE_TOKEN=hf_...YOUR_TOKEN_HERE...

# Optional: Google Search API (chưa dùng)
GOOGLE_SEARCH_API_KEY=your_key_here
GOOGLE_CSE_ID=your_cse_id_here

# Optional: GitHub API (chưa dùng)
GITHUB_TOKEN=ghp_your_token_here

# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_secure_password_here

# Google Drive Upload Configuration
GOOGLE_DRIVE_UPLOAD_URL=https://drive.google.com/drive/folders/...

# last30days — Social media research engine
# See: services/chatbot/vendor/last30days/README.md
LAST30DAYS_ENABLED=false
LAST30DAYS_SCRIPT_PATH=
LAST30DAYS_PYTHON_PATH=
LAST30DAYS_TIMEOUT=180

# Hermes Agent — Advanced AI agent sidecar
# See: docs/deployment_last30days_hermes.md
HERMES_ENABLED=false
HERMES_API_URL=http://localhost:8080
HERMES_API_KEY=